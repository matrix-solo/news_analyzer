# ==================== 新闻分析工作流 - 环境变量模板 ====================
# 复制此文件为 .env 并填入真实密钥，切勿将 .env 提交到 Git

# ==================== AI 模型配置 ====================
# 说明：深度分析和快速筛选可能使用不同模型
# 格式：AI_<用途>_<信息类型> = <值>
# 用途：ANALYSIS(深度分析) / FILTER(快速筛选) / BACKUP(备用)
# 信息类型：PROVIDER(厂商) / MODEL(模型名) / KEY(密钥) / BASE_URL(API地址，可选)

# ---------- 深度分析模型 ----------
AI_ANALYSIS_PROVIDER=
AI_ANALYSIS_MODEL=
AI_ANALYSIS_KEY=
AI_ANALYSIS_BASE_URL=

# ---------- 快速筛选模型 ----------
AI_FILTER_PROVIDER=
AI_FILTER_MODEL=
AI_FILTER_KEY=
AI_FILTER_BASE_URL=

# ---------- 备用模型（可选）----------
AI_BACKUP_PROVIDER=
AI_BACKUP_MODEL=
AI_BACKUP_KEY=
AI_BACKUP_BASE_URL=

# ==================== 新闻源 API ====================
NEWS_API_KEY=your-newsapi-key-here

# ==================== 热榜 API ====================
HOTBOARD_API_KEY=your-uapi-key-here

# ==================== 代理配置（可选）====================
# 注意：如果没有科学上网工具或合规代理，可能无法获取部分国际新闻源
# GitHub Actions 运行时无需配置，服务器可直接访问国际源
# 本地开发时如有需要，取消注释并填入实际端口
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=.xinhuanet.com,.people.com.cn

# ==================== 邮件推送（可选）====================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_auth_code
EMAIL_TO=recipient@example.com

# ==================== 报告配置（可选）====================
# 是否启用投资分析模块（默认关闭以节约成本）
ENABLE_INVESTMENT_ANALYSIS=false

# ==================== AI 处理配置（可选）====================
# AI 批处理大小（每批发送给 AI 的新闻数量，默认 4）
# 建议值：2-10，内容较长时可减小此值避免超时
AI_BATCH_SIZE=4

# ==================== 日志配置（可选）====================
LOG_LEVEL=INFO
TEMP_DIR=
