"""жЈҖжҹҘж•°жҚ®еә“зҠ¶жҖ?""

import sys
sys.path.insert(0, 'c:\\Users\\matrix\\Desktop\\news_workflow\\news_analyzer')

from core.storage.database import get_db

def check_data():
    db = get_db()
    
    # иҺ·еҸ–жңҖиҝ?8е°Ҹж—¶зҡ„ж–°й—?    recent = db.get_recent_news(hours=48)
    print(f"жңҖиҝ?8е°Ҹж—¶ж–°й—»: {len(recent)}жқ?)
    
    # з»ҹи®ЎйўҶеҹҹ
    domain_counts = {}
    unclassified = []
    
    for news in recent:
        domain = news.get('domain')
        if not domain:
            unclassified.append(news)
            domain = 'жңӘеҲҶзұ?
        domain_counts[domain] = domain_counts.get(domain, 0) + 1
    
    print("\nйўҶеҹҹеҲҶеёғ:")
    for domain, count in sorted(domain_counts.items(), key=lambda x: -x[1]):
        print(f"  {domain}: {count}жқ?)
    
    print(f"\nжңӘеҲҶзұ»ж–°й—? {len(unclassified)}жқ?)
    
    # жЈҖжҹҘж”ҝжІ»гҖҒз»ҸжөҺгҖҒз§‘жҠҖ
    print("\nйҮҚзӮ№жЈҖжҹ?")
    for domain in ['ж”ҝжІ»', 'з»ҸжөҺ', 'з§‘жҠҖ']:
        count = domain_counts.get(domain, 0)
        status = "вң? if count > 0 else "вқ?
        print(f"{status} {domain}: {count}жқ?)

if __name__ == "__main__":
    check_data()

