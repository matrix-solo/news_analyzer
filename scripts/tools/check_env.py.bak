#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
жЈҖжҹҘзҺҜеўғеҸҳйҮҸеҠ иҪ?"""

import sys
import os

current_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, current_dir)

from core.config.loader import get_env

def mask_key(key: str) -> str:
    """и„ұж•ҸжҳҫзӨәAPI Key"""
    if not key:
        return "(жңӘи®ҫзҪ?"
    if len(key) <= 8:
        return "****"
    return f"{key[:4]}...{key[-4:]}"

def check_env():
    """жЈҖжҹҘзҺҜеўғеҸҳйҮҸеҠ иҪ?""
    print("жЈҖжҹҘзҺҜеўғеҸҳйҮҸеҠ иҪ?..")
    print("-" * 50)
    
    keys_to_check = [
        ("DEEPSEEK_API_KEY", "DeepSeek API"),
        ("ARK_API_KEY", "иұҶеҢ… API"),
        ("DOUBAO_API_KEY", "иұҶеҢ… API (еӨҮз”Ё)"),
        ("QWEN_API_KEY", "йҖҡд№үеҚғй—® API"),
        ("DASHSCOPE_API_KEY", "DashScope API"),
        ("NEWS_API_KEY", "NewsAPI"),
    ]
    
    for key, name in keys_to_check:
        value = get_env(key)
        masked = mask_key(value)
        status = "вң? if value else "вқ?
        print(f"{status} {name}: {masked}")
    
    print("-" * 50)
    print("жЈҖжҹҘе®ҢжҲҗпјҒ")

if __name__ == "__main__":
    check_env()

