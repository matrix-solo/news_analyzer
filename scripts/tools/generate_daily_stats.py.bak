#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
жҜҸж—Ҙз»ҹи®ЎжҠҘе‘Ҡз”ҹжҲҗеҷ?з”ЁйҖ”пјҡз”ҹжҲҗйҮҮйӣҶгҖҒAIеҲҶжһҗгҖҒжҠҘе‘ҠжҺЁйҖҒзҡ„ж ёеҝғжҢҮж Үз»ҹи®Ў
"""

import json
import logging
import sqlite3
from pathlib import Path
from datetime import datetime, timedelta
from typing import Dict, List, Any

logger = logging.getLogger("DailyStats")


class DailyStatsGenerator:
    """жҜҸж—Ҙз»ҹи®ЎжҠҘе‘Ҡз”ҹжҲҗеҷ?""
    
    def __init__(self, db_path: str = None, stats_dir: str = None):
        """
        еҲқе§ӢеҢ–з»ҹи®Ўз”ҹжҲҗеҷЁ
        
        Args:
            db_path: ж•°жҚ®еә“и·Ҝеҫ?            stats_dir: з»ҹи®ЎжҠҘе‘Ҡиҫ“еҮәзӣ®еҪ•
        """
        self.db_path = db_path or str(Path(__file__).parent.parent / "data" / "news.db")
        self.stats_dir = Path(stats_dir or Path(__file__).parent.parent / "data" / "stats")
        self.stats_dir.mkdir(parents=True, exist_ok=True)
    
    def generate(self, date: str = None) -> Dict[str, Any]:
        """
        з”ҹжҲҗжҢҮе®ҡж—Ҙжңҹзҡ„з»ҹи®ЎжҠҘе‘?        
        Args:
            date: ж—Ҙжңҹеӯ—з¬ҰдёІпјҲYYYY-MM-DDпјүпјҢй»ҳи®Өд»ҠеӨ©
        
        Returns:
            з»ҹи®Ўж•°жҚ®еӯ—е…ё
        """
        if not date:
            date = datetime.now().strftime("%Y-%m-%d")
        
        stats = {
            "date": date,
            "generated_at": datetime.now().isoformat(),
            "collection": self._get_collection_stats(date),
            "ai_analysis": self._get_ai_analysis_stats(date),
            "database": self._get_database_stats(),
            "report": self._get_report_stats(date),
        }
        
        # дҝқеӯҳ JSON жҠҘе‘Ҡ
        json_path = self.stats_dir / f"stats_{date}.json"
        with open(json_path, "w", encoding="utf-8") as f:
            json.dump(stats, f, ensure_ascii=False, indent=2)
        
        # з”ҹжҲҗ Markdown жҠҘе‘Ҡ
        md_path = self.stats_dir / f"stats_{date}.md"
        self._generate_markdown_report(stats, md_path)
        
        logger.info(f"з»ҹи®ЎжҠҘе‘Ҡе·Із”ҹжҲ? {md_path}")
        
        return stats
    
    def _get_collection_stats(self, date: str) -> Dict[str, Any]:
        """иҺ·еҸ–йҮҮйӣҶз»ҹи®Ў"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            
            # еҪ“ж—ҘйҮҮйӣҶж•°йҮҸ
            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE DATE(created_at) = ?
            """, (date,))
            total_collected = cursor.fetchone()[0]
            
            # жҢүжқҘжәҗз»ҹи®?            cursor.execute("""
                SELECT source_name, COUNT(*) as count
                FROM news 
                WHERE DATE(created_at) = ?
                GROUP BY source_name
                ORDER BY count DESC
            """, (date,))
            by_source = dict(cursor.fetchall())
            
            # жҢүйўҶеҹҹз»ҹи®?            cursor.execute("""
                SELECT domain, COUNT(*) as count
                FROM news 
                WHERE DATE(created_at) = ? AND domain IS NOT NULL
                GROUP BY domain
                ORDER BY count DESC
            """, (date,))
            by_domain = dict(cursor.fetchall())
            
            return {
                "total_collected": total_collected,
                "successful_sources": len([s for s, c in by_source.items() if c > 0]),
                "failed_sources": 0,  # йңҖиҰҒд»Һж—Ҙеҝ—и§Јжһҗ
                "by_source": by_source,
                "by_domain": by_domain,
            }
    
    def _get_ai_analysis_stats(self, date: str) -> Dict[str, Any]:
        """иҺ·еҸ– AI еҲҶжһҗз»ҹи®Ў"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            
            # еҪ“ж—ҘеӨ„зҗҶж•°йҮҸ
            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE DATE(created_at) = ? AND score IS NOT NULL
            """, (date,))
            total_processed = cursor.fetchone()[0]
            
            # йҖҡиҝҮж•°йҮҸпјҲscore >= 60пј?            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE DATE(created_at) = ? AND score >= 60
            """, (date,))
            passed = cursor.fetchone()[0]
            
            # жӢ’з»қж•°йҮҸпјҲscore < 60пј?            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE DATE(created_at) = ? AND score IS NOT NULL AND score < 60
            """, (date,))
            rejected = cursor.fetchone()[0]
            
            # е…ңеә•ж•°йҮҸпјҲscore = 50пј?            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE DATE(created_at) = ? AND score = 50
            """, (date,))
            fallback = cursor.fetchone()[0]
            
            # е№іеқҮеҲҶж•°
            cursor.execute("""
                SELECT AVG(score) FROM news 
                WHERE DATE(created_at) = ? AND score IS NOT NULL
            """, (date,))
            avg_score = cursor.fetchone()[0] or 0
            
            # жҲҗеҠҹзҺ?            success_rate = (passed / total_processed * 100) if total_processed > 0 else 0
            
            return {
                "total_processed": total_processed,
                "passed": passed,
                "rejected": rejected,
                "fallback": fallback,
                "success_rate": round(success_rate, 1),
                "avg_score": round(avg_score, 1),
            }
    
    def _get_database_stats(self) -> Dict[str, Any]:
        """иҺ·еҸ–ж•°жҚ®еә“з»ҹи®?""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            
            # жҖ»ж–°й—»ж•°
            cursor.execute("SELECT COUNT(*) FROM news")
            total_news = cursor.fetchone()[0]
            
            # жңҖиҝ?24 е°Ҹж—¶
            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE created_at > datetime('now', '-24 hours')
            """)
            recent_24h = cursor.fetchone()[0]
            
            # жңҖиҝ?7 еӨ?            cursor.execute("""
                SELECT COUNT(*) FROM news 
                WHERE created_at > datetime('now', '-7 days')
            """)
            recent_7d = cursor.fetchone()[0]
            
            # ж•°жҚ®еә“еӨ§е°?            db_size = Path(self.db_path).stat().st_size / 1024 / 1024  # MB
            
            return {
                "total_news": total_news,
                "recent_24h": recent_24h,
                "recent_7d": recent_7d,
                "db_size_mb": round(db_size, 2),
            }
    
    def _get_report_stats(self, date: str) -> Dict[str, Any]:
        """иҺ·еҸ–жҠҘе‘Ҡз»ҹи®Ў"""
        reports_dir = Path(__file__).parent.parent / "reports"
        
        # жЈҖжҹҘеҪ“ж—ҘжҠҘе‘ҠжҳҜеҗҰеӯҳең?        report_files = list(reports_dir.glob(f"daily_report_{date}*.md"))
        pdf_files = list(reports_dir.glob(f"daily_report_{date}*.pdf"))
        
        return {
            "generated": len(report_files) > 0,
            "email_sent": False,  # йңҖиҰҒд»Һж—Ҙеҝ—и§Јжһҗ
            "report_files": len(report_files),
            "pdf_files": len(pdf_files),
        }
    
    def _generate_markdown_report(self, stats: Dict[str, Any], output_path: Path):
        """з”ҹжҲҗ Markdown ж јејҸзҡ„з»ҹи®ЎжҠҘе‘?""
        lines = [
            f"# жҜҸж—Ҙз»ҹи®ЎжҠҘе‘Ҡ - {stats['date']}",
            "",
            f"з”ҹжҲҗж—¶й—ҙ: {stats['generated_at']}",
            "",
            "## рҹ“Ҡ йҮҮйӣҶз»ҹи®Ў",
            "",
            f"- **жҖ»йҮҮйӣ?*: {stats['collection']['total_collected']} жқ?,
            f"- **жҲҗеҠҹжә?*: {stats['collection']['successful_sources']} дё?,
            "",
            "### жҢүжқҘжәҗз»ҹи®?,
            "",
        ]
        
        for source, count in list(stats['collection']['by_source'].items())[:10]:
            lines.append(f"- {source}: {count} жқ?)
        
        lines.extend([
            "",
            "## рҹӨ– AI еҲҶжһҗз»ҹи®Ў",
            "",
            f"- **еӨ„зҗҶж•?*: {stats['ai_analysis']['total_processed']} жқ?,
            f"- **йҖҡиҝҮ**: {stats['ai_analysis']['passed']} жқ?({stats['ai_analysis']['success_rate']}%)",
            f"- **жӢ’з»қ**: {stats['ai_analysis']['rejected']} жқ?,
            f"- **е…ңеә•**: {stats['ai_analysis']['fallback']} жқ?,
            f"- **е№іеқҮеҲ?*: {stats['ai_analysis']['avg_score']}",
            "",
            "## рҹ’ҫ ж•°жҚ®еә“з»ҹи®?,
            "",
            f"- **жҖ»ж–°й—?*: {stats['database']['total_news']} жқ?,
            f"- **жңҖиҝ?24h**: {stats['database']['recent_24h']} жқ?,
            f"- **жңҖиҝ?7d**: {stats['database']['recent_7d']} жқ?,
            f"- **ж•°жҚ®еә“еӨ§е°?*: {stats['database']['db_size_mb']} MB",
            "",
            "## рҹ“§ жҠҘе‘Ҡз»ҹи®Ў",
            "",
            f"- **жҠҘе‘Ҡз”ҹжҲҗ**: {'вң? if stats['report']['generated'] else 'вқ?}",
            f"- **йӮ®д»¶еҸ‘йҖ?*: {'вң? if stats['report']['email_sent'] else 'вқ?}",
            "",
        ])
        
        with open(output_path, "w", encoding="utf-8") as f:
            f.write("\n".join(lines))


def main():
    """дё»еҮҪж•?""
    import argparse
    
    parser = argparse.ArgumentParser(description="з”ҹжҲҗжҜҸж—Ҙз»ҹи®ЎжҠҘе‘Ҡ")
    parser.add_argument("--date", help="жҢҮе®ҡж—ҘжңҹпјҲYYYY-MM-DDпјүпјҢй»ҳи®Өд»ҠеӨ©")
    parser.add_argument("--output", help="иҫ“еҮәзӣ®еҪ•")
    
    args = parser.parse_args()
    
    generator = DailyStatsGenerator(stats_dir=args.output)
    stats = generator.generate(date=args.date)
    
    print(f"\nрҹ“Ҡ з»ҹи®ЎжҠҘе‘Ҡе·Із”ҹжҲ?")
    print(f"  - йҮҮйӣҶ: {stats['collection']['total_collected']} жқ?)
    print(f"  - AI йҖҡиҝҮ: {stats['ai_analysis']['passed']} жқ?({stats['ai_analysis']['success_rate']}%)")
    print(f"  - ж•°жҚ®еә? {stats['database']['total_news']} жқ?)


if __name__ == "__main__":
    main()

