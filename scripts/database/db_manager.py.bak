#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
ж•°жҚ®еә“з®ЎзҗҶCLIе·Ҙе…·

еҠҹиғҪпј?1. жҹҘзңӢж•°жҚ®еә“з»ҹи®ЎдҝЎжҒ?2. жҹҘиҜўзү№е®ҡж–°й—»
3. ж•°жҚ®иҙЁйҮҸжЈҖжҹ?4. ж•°жҚ®еҜјеҮә
"""

import sys
import json
import argparse
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional

project_root = Path(__file__).parent.parent
sys.path.insert(0, str(project_root))

from core.storage.database import NewsDatabase
from core.config.loader import PROJECT_ROOT


class DatabaseManager:
    """ж•°жҚ®еә“з®ЎзҗҶеҷЁ"""
    
    def __init__(self):
        self.db = NewsDatabase()
    
    def show_stats(self):
        """жҳҫзӨәж•°жҚ®еә“з»ҹи®ЎдҝЎжҒ?""
        stats = self.db.get_stats()
        
        print("\n" + "=" * 60)
        print("рҹ“Ҡ ж•°жҚ®еә“з»ҹи®ЎдҝЎжҒ?)
        print("=" * 60)
        print(f"\nрҹ“Ұ жҖ»ж–°й—»ж•°: {stats['total_news']:,}")
        print(f"рҹ“… жңҖиҝ?4е°Ҹж—¶: {stats['recent_24h']:,}")
        print(f"рҹ“… жңҖиҝ?еӨ? {stats['recent_7d']:,}")
        print(f"рҹ“… жңҖиҝ?0еӨ? {stats['recent_30d']:,}")
        print(f"вң?е·ІеӨ„зҗҶж•°: {stats['processed']:,}")
        
        if stats['by_domain']:
            print("\nрҹ“Ҳ йўҶеҹҹеҲҶеёғ:")
            for domain, count in sorted(stats['by_domain'].items(), key=lambda x: -x[1]):
                bar = "в–? * min(20, count // 5)
                print(f"  {domain:8s}: {count:5d} {bar}")
        
        print("\n" + "=" * 60)
    
    def show_recent(self, hours: int = 24, domain: str = None, limit: int = 20):
        """жҳҫзӨәжңҖиҝ‘ж–°й—?""
        if domain:
            news_list = self.db.search_by_domain(domain, hours)
            print(f"\nрҹ“° жңҖиҝ‘{hours}е°Ҹж—¶ {domain} йўҶеҹҹж–°й—» (е…ұ{len(news_list)}жқ?")
        else:
            news_list = self.db.get_recent_news(hours)
            print(f"\nрҹ“° жңҖиҝ‘{hours}е°Ҹж—¶ж–°й—» (е…ұ{len(news_list)}жқ?")
        
        print("=" * 80)
        
        for i, news in enumerate(news_list[:limit], 1):
            title = news.get('translated_title') or news.get('title', 'ж— ж Үйў?)
            score = news.get('score', 0)
            source = news.get('source_name', 'жңӘзҹҘ')
            domain_val = news.get('domain', 'е…¶д»–')
            pub_date = news.get('pub_date', '')[:10] if news.get('pub_date') else 'жңӘзҹҘ'
            
            score_icon = "рҹ”Ҙ" if score >= 80 else "вӯ? if score >= 60 else "рҹ“„"
            
            print(f"\n{i}. {score_icon} [{score:.0f}еҲҶ] {title[:50]}...")
            print(f"   жқҘжәҗ: {source} | йўҶеҹҹ: {domain_val} | ж—Ҙжңҹ: {pub_date}")
        
        if len(news_list) > limit:
            print(f"\n... иҝҳжңү {len(news_list) - limit} жқЎж–°й—»жңӘжҳҫзӨә")
        
        print("\n" + "=" * 80)
    
    def search(self, keyword: str, days: int = 30):
        """жҗңзҙўж–°й—»"""
        keywords = [k.strip() for k in keyword.split(',')]
        news_list = self.db.search_by_keywords(keywords, days)
        
        print(f"\nрҹ”Қ жҗңзҙўз»“жһң: '{keyword}' (иҝ‘{days}еӨ©пјҢе…ұ{len(news_list)}жқ?")
        print("=" * 80)
        
        for i, news in enumerate(news_list[:20], 1):
            title = news.get('translated_title') or news.get('title', 'ж— ж Үйў?)
            score = news.get('score', 0)
            source = news.get('source_name', 'жңӘзҹҘ')
            
            print(f"\n{i}. [{score:.0f}еҲҶ] {title[:60]}...")
            print(f"   жқҘжәҗ: {source}")
        
        if len(news_list) > 20:
            print(f"\n... иҝҳжңү {len(news_list) - 20} жқЎз»“жһңжңӘжҳҫзӨә")
        
        print("\n" + "=" * 80)
    
    def show_detail(self, news_id: str):
        """жҳҫзӨәж–°й—»иҜҰжғ…"""
        with self.db.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM news WHERE id = ? OR id LIKE ?', (news_id, f'%{news_id}%'))
            row = cursor.fetchone()
            
            if not row:
                print(f"\nвқ?жңӘжүҫеҲ°ж–°й—? {news_id}")
                return
            
            news = dict(row)
            
            print("\n" + "=" * 60)
            print("рҹ“„ ж–°й—»иҜҰжғ…")
            print("=" * 60)
            
            print(f"\nрҹ“Ң ж Үйўҳ: {news.get('title', 'ж—?)}")
            if news.get('translated_title'):
                print(f"рҹ“Ң иҜ‘еҗҚ: {news['translated_title']}")
            
            print(f"\nрҹ“° жқҘжәҗ: {news.get('source_name', 'жңӘзҹҘ')}")
            print(f"рҹ“… еҸ‘еёғж—¶й—ҙ: {news.get('pub_date', 'жңӘзҹҘ')}")
            print(f"рҹ”— й“ҫжҺҘ: {news.get('link', 'ж—?)}")
            
            print(f"\nрҹҸ·пё?йўҶеҹҹ: {news.get('domain', 'е…¶д»–')}")
            tags = news.get('tags', '[]')
            if isinstance(tags, str):
                try:
                    tags = json.loads(tags)
                except:
                    tags = []
            if tags:
                print(f"рҹҸ·пё?ж Үзӯҫ: {', '.join(tags)}")
            
            print(f"\nвӯ?з»јеҗҲиҜ„еҲҶ: {news.get('score', 0):.1f}")
            print(f"   - дҝЎжәҗеҲ? {news.get('score_credibility', 0):.1f}")
            print(f"   - еҪұе“ҚеҠ? {news.get('score_importance', 0):.1f}")
            print(f"   - ж—¶ж•ҲжҖ? {news.get('score_timeliness', 0):.1f}")
            print(f"   - д»·еҖјеҲҶ: {news.get('score_impact', 0):.1f}")
            
            print("\nрҹ“қ 5W1H еҲҶжһҗ:")
            print(f"   - дҪ•дәә: {news.get('who', 'ж—?)}")
            print(f"   - дҪ•дәӢ: {news.get('what', 'ж—?)}")
            print(f"   - дҪ•ж—¶: {news.get('when_time', 'ж—?)}")
            print(f"   - дҪ•ең°: {news.get('where_place', 'ж—?)}")
            print(f"   - дҪ•еӣ : {news.get('why', 'ж—?)}")
            print(f"   - еҰӮдҪ•: {news.get('how', 'ж—?)}")
            
            if news.get('summary'):
                print(f"\nрҹ“Ӣ ж‘ҳиҰҒ:\n{news['summary'][:500]}...")
            
            if news.get('content'):
                print(f"\nрҹ“„ еҶ…е®№:\n{news['content'][:500]}...")
            
            print(f"\nрҹ“Ҡ и§Јжһҗж–№жі•: {news.get('extraction_method', 'жңӘзҹҘ')}")
            print(f"рҹ“… е…Ҙеә“ж—¶й—ҙ: {news.get('created_at', 'жңӘзҹҘ')}")
            
            print("\n" + "=" * 60)
    
    def check_quality(self):
        """жЈҖжҹҘж•°жҚ®иҙЁйҮ?""
        print("\n" + "=" * 60)
        print("рҹ”Қ ж•°жҚ®иҙЁйҮҸжЈҖжҹ?)
        print("=" * 60)
        
        with self.db.get_connection() as conn:
            cursor = conn.cursor()
            
            cursor.execute('SELECT COUNT(*) FROM news')
            total = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE domain IS NULL OR domain = ""')
            no_domain = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE score IS NULL OR score = 0')
            no_score = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE content IS NULL OR content = ""')
            no_content = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE who IS NULL OR who = ""')
            no_who = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE what IS NULL OR what = ""')
            no_what = cursor.fetchone()[0]
            
            cursor.execute('SELECT COUNT(*) FROM news WHERE summary IS NULL OR summary = ""')
            no_summary = cursor.fetchone()[0]
            
            cursor.execute('''
                SELECT COUNT(*) FROM news 
                WHERE who IS NULL AND what IS NULL AND when_time IS NULL 
                AND where_place IS NULL AND why IS NULL AND how IS NULL
            ''')
            no_5w1h = cursor.fetchone()[0]
        
        print(f"\nрҹ“Ұ жҖ»и®°еҪ•ж•°: {total:,}")
        
        print("\nвҡ пёҸ ж•°жҚ®зјәеӨұз»ҹи®Ў:")
        
        issues = []
        if no_domain > 0:
            pct = no_domain / total * 100
            issues.append(f"  - ж— йўҶеҹҹж Үзӯ? {no_domain:,} ({pct:.1f}%)")
        if no_score > 0:
            pct = no_score / total * 100
            issues.append(f"  - ж— иҜ„еҲ? {no_score:,} ({pct:.1f}%)")
        if no_content > 0:
            pct = no_content / total * 100
            issues.append(f"  - ж— еҶ…е®? {no_content:,} ({pct:.1f}%)")
        if no_summary > 0:
            pct = no_summary / total * 100
            issues.append(f"  - ж— ж‘ҳиҰ? {no_summary:,} ({pct:.1f}%)")
        if no_5w1h > 0:
            pct = no_5w1h / total * 100
            issues.append(f"  - ж—?W1H: {no_5w1h:,} ({pct:.1f}%)")
        
        if issues:
            print("\n".join(issues))
        else:
            print("  вң?ж•°жҚ®иҙЁйҮҸиүҜеҘҪпјҢж— зјәеӨұеӯ—ж®ө")
        
        quality_score = (total - no_domain - no_score - no_content) / total * 100 if total > 0 else 0
        print(f"\nрҹ“Ҡ ж•°жҚ®иҙЁйҮҸиҜ„еҲҶ: {quality_score:.1f}%")
        
        print("\n" + "=" * 60)
    
    def export(self, output_file: str, days: int = 30, domain: str = None):
        """еҜјеҮәж•°жҚ®"""
        if domain:
            news_list = self.db.search_by_domain(domain, days * 24)
        else:
            news_list = self.db.get_history_news(days)
        
        output_path = Path(output_file)
        
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(news_list, f, ensure_ascii=False, indent=2)
        
        print(f"\nвң?е·ІеҜјеҮ?{len(news_list)} жқЎж–°й—»еҲ°: {output_path}")
    
    def show_rejected_stats(self):
        """жҳҫзӨәиў«жӢ’з»қж–°й—»з»ҹи®?""
        log_dir = PROJECT_ROOT / "data" / "filter_logs"
        
        if not log_dir.exists():
            print("\nвқ?жңӘжүҫеҲ°иҝҮж»Өж—Ҙеҝ—зӣ®еҪ?)
            return
        
        print("\n" + "=" * 60)
        print("рҹ“Ҡ иў«жӢ’з»қж–°й—»з»ҹи®?)
        print("=" * 60)
        
        total_rejected = 0
        reason_counts = {}
        
        for log_file in log_dir.glob("ai_filter_*.jsonl"):
            try:
                with open(log_file, 'r', encoding='utf-8') as f:
                    for line in f:
                        try:
                            log = json.loads(line)
                            if log.get('action') == 'fact_check':
                                result = log.get('result', {})
                                if not result.get('is_factual', True):
                                    total_rejected += 1
                                    reason = result.get('content_type', 'жңӘзҹҘ')
                                    reason_counts[reason] = reason_counts.get(reason, 0) + 1
                        except:
                            pass
            except:
                pass
        
        print(f"\nрҹ“Ұ жҖ»жӢ’з»қж•°: {total_rejected:,}")
        
        if reason_counts:
            print("\nрҹ“Ӣ жӢ’з»қеҺҹеӣ еҲҶеёғ:")
            for reason, count in sorted(reason_counts.items(), key=lambda x: -x[1]):
                pct = count / total_rejected * 100 if total_rejected > 0 else 0
                print(f"  - {reason}: {count:,} ({pct:.1f}%)")
        
        print("\n" + "=" * 60)


def main():
    parser = argparse.ArgumentParser(description="ж•°жҚ®еә“з®ЎзҗҶCLIе·Ҙе…·")
    subparsers = parser.add_subparsers(dest="command", help="еҸҜз”Ёе‘Ҫд»Ө")
    
    parser_stats = subparsers.add_parser("stats", help="жҳҫзӨәж•°жҚ®еә“з»ҹи®?)
    
    parser_recent = subparsers.add_parser("recent", help="жҳҫзӨәжңҖиҝ‘ж–°й—?)
    parser_recent.add_argument("--hours", type=int, default=24, help="ж—¶й—ҙиҢғеӣҙпјҲе°Ҹж—¶пјү")
    parser_recent.add_argument("--domain", type=str, help="жҢүйўҶеҹҹзӯӣйҖ?)
    parser_recent.add_argument("--limit", type=int, default=20, help="жҳҫзӨәж•°йҮҸ")
    
    parser_search = subparsers.add_parser("search", help="жҗңзҙўж–°й—»")
    parser_search.add_argument("keyword", help="жҗңзҙўе…ій”®иҜҚпјҲйҖ—еҸ·еҲҶйҡ”еӨҡдёӘпј?)
    parser_search.add_argument("--days", type=int, default=30, help="жҗңзҙўеӨ©ж•°")
    
    parser_detail = subparsers.add_parser("detail", help="жҳҫзӨәж–°й—»иҜҰжғ…")
    parser_detail.add_argument("news_id", help="ж–°й—»ID")
    
    parser_quality = subparsers.add_parser("quality", help="жЈҖжҹҘж•°жҚ®иҙЁйҮ?)
    
    parser_export = subparsers.add_parser("export", help="еҜјеҮәж•°жҚ®")
    parser_export.add_argument("output", help="иҫ“еҮәж–Үд»¶и·Ҝеҫ„")
    parser_export.add_argument("--days", type=int, default=30, help="еҜјеҮәеӨ©ж•°")
    parser_export.add_argument("--domain", type=str, help="жҢүйўҶеҹҹзӯӣйҖ?)
    
    parser_rejected = subparsers.add_parser("rejected", help="жҳҫзӨәиў«жӢ’з»қж–°й—»з»ҹи®?)
    
    args = parser.parse_args()
    
    manager = DatabaseManager()
    
    if args.command == "stats":
        manager.show_stats()
    elif args.command == "recent":
        manager.show_recent(args.hours, args.domain, args.limit)
    elif args.command == "search":
        manager.search(args.keyword, args.days)
    elif args.command == "detail":
        manager.show_detail(args.news_id)
    elif args.command == "quality":
        manager.check_quality()
    elif args.command == "export":
        manager.export(args.output, args.days, args.domain)
    elif args.command == "rejected":
        manager.show_rejected_stats()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()

