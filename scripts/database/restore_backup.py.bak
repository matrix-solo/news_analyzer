#!/usr/bin/env python3
"""еӨҮд»ҪжҒўеӨҚи„ҡжң¬"""

import os
import sys
import shutil
import argparse
from pathlib import Path
from datetime import datetime
from typing import Optional

def list_backups() -> list:
    """еҲ—еҮәжүҖжңүеҸҜз”ЁеӨҮд»?""
    backup_dir = Path("data/backups")
    
    if not backup_dir.exists():
        return []
    
    backups = sorted(
        backup_dir.glob("news.db.backup_*"),
        key=lambda x: x.stat().st_mtime,
        reverse=True
    )
    
    return backups

def restore_backup(backup_file: Path, force: bool = False) -> bool:
    """д»ҺеӨҮд»ҪжҒўеӨҚж•°жҚ®еә“"""
    if not backup_file.exists():
        print(f"вқ?еӨҮд»Ҫж–Үд»¶дёҚеӯҳең? {backup_file}")
        return False
    
    db_path = Path("data/news.db")
    
    if db_path.exists() and not force:
        print(f"вҡ пёҸ  ж•°жҚ®еә“ж–Үд»¶е·ІеӯҳеңЁ: {db_path}")
        print("дҪҝз”Ё --force еҸӮж•°ејәеҲ¶иҰҶзӣ–")
        return False
    
    try:
        if db_path.exists():
            corrupt_path = db_path.parent / f"{db_path.name}.corrupt_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
            shutil.move(str(db_path), str(corrupt_path))
            print(f"рҹ“Ұ е·Іе°ҶеҺҹж•°жҚ®еә“з§»еҠЁеҲ? {corrupt_path}")
        
        shutil.copy2(backup_file, db_path)
        
        print(f"вң?ж•°жҚ®еә“жҒўеӨҚжҲҗеҠ? {backup_file}")
        print(f"   жҒўеӨҚеҲ? {db_path}")
        
        backup_time = datetime.fromtimestamp(backup_file.stat().st_mtime)
        print(f"   еӨҮд»Ҫж—¶й—ҙ: {backup_time.strftime('%Y-%m-%d %H:%M:%S')}")
        print(f"   ж–Үд»¶еӨ§е°Ҹ: {backup_file.stat().st_size / 1024 / 1024:.2f} MB")
        
        return True
        
    except Exception as e:
        print(f"вқ?жҒўеӨҚеӨұиҙҘ: {e}")
        return False

def main():
    """дё»еҮҪж•?""
    parser = argparse.ArgumentParser(description="ж•°жҚ®еә“еӨҮд»ҪжҒўеӨҚе·Ҙе…?)
    parser.add_argument("--list", action="store_true", help="еҲ—еҮәжүҖжңүеҸҜз”ЁеӨҮд»?)
    parser.add_argument("--latest", action="store_true", help="дҪҝз”ЁжңҖж–°еӨҮд»ҪжҒўеӨ?)
    parser.add_argument("--file", type=str, help="жҢҮе®ҡеӨҮд»Ҫж–Үд»¶и·Ҝеҫ„")
    parser.add_argument("--force", action="store_true", help="ејәеҲ¶иҰҶзӣ–зҺ°жңүж•°жҚ®еә?)
    
    args = parser.parse_args()
    
    print("=" * 60)
    print("рҹ”„ ж•°жҚ®еә“еӨҮд»ҪжҒўеӨҚе·Ҙе…?)
    print("=" * 60)
    
    if args.list:
        backups = list_backups()
        
        if not backups:
            print("вқ?жІЎжңүжүҫеҲ°еӨҮд»Ҫж–Үд»¶")
            return 1
        
        print(f"\nжүҫеҲ° {len(backups)} дёӘеӨҮд»Ҫж–Үд»?\n")
        print(f"{'еәҸеҸ·':<6} {'ж–Үд»¶еҗ?:<40} {'еӨ§е°Ҹ':<12} {'ж—¶й—ҙ'}")
        print("-" * 80)
        
        for i, backup in enumerate(backups, 1):
            size = backup.stat().st_size / 1024 / 1024
            mtime = datetime.fromtimestamp(backup.stat().st_mtime)
            print(f"{i:<6} {backup.name:<40} {size:>8.2f} MB  {mtime.strftime('%Y-%m-%d %H:%M:%S')}")
        
        return 0
    
    backup_file = None
    
    if args.latest:
        backups = list_backups()
        if backups:
            backup_file = backups[0]
            print(f"рҹ“Ң дҪҝз”ЁжңҖж–°еӨҮд»? {backup_file.name}")
        else:
            print("вқ?жІЎжңүжүҫеҲ°еӨҮд»Ҫж–Үд»¶")
            return 1
    
    elif args.file:
        backup_file = Path(args.file)
        if not backup_file.exists():
            backup_dir = Path("data/backups")
            backup_file = backup_dir / args.file
            
            if not backup_file.exists():
                print(f"вқ?еӨҮд»Ҫж–Үд»¶дёҚеӯҳең? {args.file}")
                return 1
    
    else:
        print("иҜ·жҢҮе®ҡжҒўеӨҚж–№еј?")
        print("  --latest    дҪҝз”ЁжңҖж–°еӨҮд»?)
        print("  --file FILE жҢҮе®ҡеӨҮд»Ҫж–Үд»¶")
        print("  --list      еҲ—еҮәжүҖжңүеӨҮд»?)
        return 1
    
    print(f"\nеҮҶеӨҮд»ҺеӨҮд»ҪжҒўеӨ? {backup_file}")
    print(f"еӨҮд»Ҫж—¶й—ҙ: {datetime.fromtimestamp(backup_file.stat().st_mtime).strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"ж–Үд»¶еӨ§е°Ҹ: {backup_file.stat().st_size / 1024 / 1024:.2f} MB")
    
    if not args.force:
        confirm = input("\nзЎ®и®ӨжҒўеӨҚ? (y/N): ")
        if confirm.lower() != 'y':
            print("вқ?е·ІеҸ–ж¶ҲжҒўеӨ?)
            return 1
    
    success = restore_backup(backup_file, force=args.force)
    
    return 0 if success else 1

if __name__ == "__main__":
    sys.exit(main())

